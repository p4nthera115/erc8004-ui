{
  "name": "erc8004-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx --tsconfig tsconfig.app.json scripts/generate-llms.ts && puppeteer browsers install chrome",
    "build": "tsc -b && vite build",
    "build:registry": "pnpm -C packages/registry build",
    "build:mcp": "pnpm -C packages/mcp-server build",
    "build:packages": "pnpm build:registry && pnpm build:mcp",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.168.8",
    "motion": "^12.38.0",
    "puppeteer": "^24.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "valibot": "^1.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@tanstack/router-plugin": "^1.167.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
